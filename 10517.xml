<LWM2M xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://www.openmobilealliance.org/tech/profiles/LWM2M.xsd">
    <Object ObjectType="MODefinition">
        <Name>Storage Management</Name>
        <Description1><![CDATA[This LwM2M Object provides management and monitoring of storage devices on embedded systems and routers. It supports multiple instances for managing different storage devices including internal NAND/NVMe, SD cards, and USB storage. Enables remote monitoring of storage capacity, usage, and basic management operations like mount/unmount and formatting.]]></Description1>
        <ObjectID>10517</ObjectID>
        <ObjectURN>urn:oma:lwm2m:x:10517</ObjectURN>
        <LWM2MVersion>1.0</LWM2MVersion>
        <ObjectVersion>1.0</ObjectVersion>
        <MultipleInstances>Multiple</MultipleInstances>
        <Mandatory>Optional</Mandatory>
        <Resources>
            <Item ID="0">
                <Name>Storage Name</Name>
                <Operations>RW</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Mandatory</Mandatory>
                <Type>String</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Descriptive name of the storage device (e.g., "System_NAND", "NVMe_SSD", "USB_Storage", "SD_Card").]]></Description>
            </Item>
            <Item ID="1">
                <Name>Storage Type</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Mandatory</Mandatory>
                <Type>Integer</Type>
                <RangeEnumeration>0..3</RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Storage device type: 0=NAND Flash, 1=NVMe SSD, 2=USB Storage, 3=SD Card.]]></Description>
            </Item>
            <Item ID="2">
                <Name>Mount Point</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Mandatory</Mandatory>
                <Type>String</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Filesystem mount point path (e.g., "/", "/mnt/nvme", "/mnt/usb"). This is where the storage is accessible in the filesystem.]]></Description>
            </Item>
            <Item ID="3">
                <Name>Total Capacity</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Mandatory</Mandatory>
                <Type>Integer</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units>KiB</Units>
                <Description><![CDATA[Total storage capacity in kibibytes.]]></Description>
            </Item>
            <Item ID="4">
                <Name>Used Capacity</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Mandatory</Mandatory>
                <Type>Integer</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units>KiB</Units>
                <Description><![CDATA[Currently used storage space in kibibytes.]]></Description>
            </Item>
            <Item ID="5">
                <Name>Available Capacity</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Mandatory</Mandatory>
                <Type>Integer</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units>KiB</Units>
                <Description><![CDATA[Available free storage space in kibibytes.]]></Description>
            </Item>
            <Item ID="6">
                <Name>Usage Percentage</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Mandatory</Mandatory>
                <Type>Integer</Type>
                <RangeEnumeration>0..100</RangeEnumeration>
                <Units>%</Units>
                <Description><![CDATA[Storage usage as percentage of total capacity (0-100%).]]></Description>
            </Item>
            <Item ID="7">
                <Name>Filesystem Type</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Optional</Mandatory>
                <Type>String</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Filesystem type (e.g., "ext4", "f2fs", "vfat", "exfat", "ntfs", "ubifs").]]></Description>
            </Item>
            <Item ID="8">
                <Name>Is Mounted</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Mandatory</Mandatory>
                <Type>Boolean</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Mount status: true=Currently mounted and accessible, false=Unmounted.]]></Description>
            </Item>
            <Item ID="9">
                <Name>Is Bootable</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Optional</Mandatory>
                <Type>Boolean</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Bootable flag: true=This storage contains bootable system firmware, false=Non-bootable data storage.]]></Description>
            </Item>
            <Item ID="10">
                <Name>Mount</Name>
                <Operations>E</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Optional</Mandatory>
                <Type></Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Execute to mount the storage device at its configured mount point.]]></Description>
            </Item>
            <Item ID="11">
                <Name>Unmount</Name>
                <Operations>E</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Optional</Mandatory>
                <Type></Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Execute to safely unmount the storage device. Ensures all data is written before disconnection.]]></Description>
            </Item>
            <Item ID="12">
                <Name>Format</Name>
                <Operations>E</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Optional</Mandatory>
                <Type></Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Execute to format the storage device. WARNING: This operation will erase all data on the storage device. Use with caution.]]></Description>
            </Item>
        </Resources>
        <Description2><![CDATA[]]></Description2>
    </Object>
</LWM2M>
