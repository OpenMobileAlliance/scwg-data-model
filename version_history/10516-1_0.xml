<LWM2M xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://www.openmobilealliance.org/tech/profiles/LWM2M.xsd">
    <Object ObjectType="MODefinition">
        <Name>USB Management</Name>
        <Description1><![CDATA[This LwM2M Object provides monitoring and control of USB ports on embedded devices and routers. It supports multiple instances for managing different USB ports, providing information about connected devices, power management, and port status. Useful for OpenWRT routers with USB ports for storage, modems, or other peripherals.]]></Description1>
        <ObjectID>10516</ObjectID>
        <ObjectURN>urn:oma:lwm2m:x:10516</ObjectURN>
        <LWM2MVersion>1.0</LWM2MVersion>
        <ObjectVersion>1.0</ObjectVersion>
        <MultipleInstances>Multiple</MultipleInstances>
        <Mandatory>Optional</Mandatory>
        <Resources>
            <Item ID="0">
                <Name>Port Name</Name>
                <Operations>RW</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Mandatory</Mandatory>
                <Type>String</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Descriptive name of the USB port (e.g., "USB1", "USB2", "Front_USB", "Type-C").]]></Description>
            </Item>
            <Item ID="1">
                <Name>Port Type</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Mandatory</Mandatory>
                <Type>Integer</Type>
                <RangeEnumeration>0..1</RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[USB port type: 0=USB 2.0 Type-A, 1=USB Type-C. This indicates the physical connector type and USB version.]]></Description>
            </Item>
            <Item ID="2">
                <Name>Port Enabled</Name>
                <Operations>RW</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Mandatory</Mandatory>
                <Type>Boolean</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Enable or disable the USB port. When disabled, the port is powered down and devices are not recognized.]]></Description>
            </Item>
            <Item ID="3">
                <Name>Device Connected</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Mandatory</Mandatory>
                <Type>Boolean</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[USB device connection status: true=Device connected, false=No device connected.]]></Description>
            </Item>
            <Item ID="4">
                <Name>Device Name</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Optional</Mandatory>
                <Type>String</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Name of the connected USB device as reported by the device (e.g., "SanDisk Ultra", "Huawei LTE Modem"). Empty if no device connected.]]></Description>
            </Item>
            <Item ID="5">
                <Name>Device Vendor ID</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Optional</Mandatory>
                <Type>String</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[USB Vendor ID in hexadecimal format (e.g., "0x12d1"). This identifies the device manufacturer.]]></Description>
            </Item>
            <Item ID="6">
                <Name>Device Product ID</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Optional</Mandatory>
                <Type>String</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[USB Product ID in hexadecimal format (e.g., "0x1506"). Combined with Vendor ID, this uniquely identifies the device model.]]></Description>
            </Item>
            <Item ID="7">
                <Name>Device Class</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Optional</Mandatory>
                <Type>String</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[USB device class (e.g., "Mass Storage", "Communication Device", "Human Interface", "Hub"). This indicates the device type and function.]]></Description>
            </Item>
            <Item ID="8">
                <Name>Power Enabled</Name>
                <Operations>RW</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Optional</Mandatory>
                <Type>Boolean</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Control USB port power supply: true=Power enabled, false=Power disabled. Some USB ports support power switching independent of port enable.]]></Description>
            </Item>
            <Item ID="9">
                <Name>Current Draw</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Optional</Mandatory>
                <Type>Integer</Type>
                <RangeEnumeration>0..3000</RangeEnumeration>
                <Units>mA</Units>
                <Description><![CDATA[Current drawn by the connected USB device in milliamperes. USB 2.0 standard allows up to 500mA, USB 3.0 up to 900mA, USB-C can provide higher currents.]]></Description>
            </Item>
        </Resources>
        <Description2><![CDATA[]]></Description2>
    </Object>
</LWM2M>
