<LWM2M xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://openmobilealliance.org/tech/profiles/LWM2M.xsd">
	<Object ObjectType="MODefinition">
		<Name>uCIFI Test Object</Name>
		<Description1>The uCIFI Test Object can be used to simply simulate external stimulus, anomalous conditions, or any kind of alarm.</Description1>
		<ObjectID>3463</ObjectID>
		<ObjectURN>urn:oma:lwm2m:ext:3463</ObjectURN>
		<LWM2MVersion>1.0</LWM2MVersion>
		<ObjectVersion>1.0</ObjectVersion>
		<MultipleInstances>Single</MultipleInstances>
		<Mandatory>Optional</Mandatory>
		<Resources>
			<Item ID="0">
				<Name>Test Mode Enabled</Name>
				<Operations>RW</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Mandatory</Mandatory>
				<Type>Boolean</Type>
				<RangeEnumeration/>
				<Units/>
				<Description>Return the status of the test mode. If password protection is enforced, test mode cannot be enabled by writing to this resource. Devices in production may automatically disable test mode after a certain period of time</Description>
			</Item>
			<Item ID="1">
				<Name>Test Mode Password</Name>
				<Operations>W</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Optional</Mandatory>
				<Type>String</Type>
				<RangeEnumeration/>
				<Units/>
				<Description>If password protection is enforced, test mode can be enabled only after writing the appropriate password</Description>
			</Item>
			<Item ID="2">
				<Name>Test Mode Uri</Name>
				<Operations>RW</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Mandatory</Mandatory>
				<Type>String</Type>
				<RangeEnumeration/>
				<Units/>
				<Description>Resource uri in core link syntax</Description>
			</Item>
			<Item ID="3">
				<Name>Test Mode Value</Name>
				<Operations>RW</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Mandatory</Mandatory>
				<Type>String</Type>
				<RangeEnumeration/>
				<Units/>
				<Description>Value to be written to the given resource</Description>
			</Item>
		</Resources>
		<Description2></Description2>
	</Object>
</LWM2M>
