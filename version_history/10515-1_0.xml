<LWM2M xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://www.openmobilealliance.org/tech/profiles/LWM2M.xsd">
    <Object ObjectType="MODefinition">
        <Name>GPIO Control</Name>
        <Description1><![CDATA[This LwM2M Object provides control and monitoring of GPIO (General Purpose Input/Output) pins on embedded devices. It supports management of LEDs, buttons, and general-purpose GPIO pins commonly found on OpenWRT routers. Multiple instances allow control of different GPIO resources, enabling remote status indication, user input monitoring, and custom hardware interfacing.]]></Description1>
        <ObjectID>10515</ObjectID>
        <ObjectURN>urn:oma:lwm2m:x:10515</ObjectURN>
        <LWM2MVersion>1.0</LWM2MVersion>
        <ObjectVersion>1.0</ObjectVersion>
        <MultipleInstances>Multiple</MultipleInstances>
        <Mandatory>Optional</Mandatory>
        <Resources>
            <Item ID="0">
                <Name>GPIO Name</Name>
                <Operations>RW</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Mandatory</Mandatory>
                <Type>String</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Descriptive name of the GPIO resource (e.g., "LED_STATUS", "LED_WLAN", "BUTTON_RESET", "GPIO_12").]]></Description>
            </Item>
            <Item ID="1">
                <Name>GPIO Number</Name>
                <Operations>RW</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Mandatory</Mandatory>
                <Type>Integer</Type>
                <RangeEnumeration>0..255</RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Hardware GPIO pin number as defined by the system GPIO numbering scheme.]]></Description>
            </Item>
            <Item ID="2">
                <Name>GPIO Type</Name>
                <Operations>RW</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Mandatory</Mandatory>
                <Type>Integer</Type>
                <RangeEnumeration>0..2</RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[GPIO type: 0=LED (output), 1=Button (input), 2=General GPIO (configurable input/output).]]></Description>
            </Item>
            <Item ID="3">
                <Name>Current State</Name>
                <Operations>RW</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Mandatory</Mandatory>
                <Type>Boolean</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Current state of the GPIO: true=High/On/Pressed, false=Low/Off/Released. For LEDs, true means LED is on. For buttons, true means currently pressed.]]></Description>
            </Item>
            <Item ID="4">
                <Name>Blink Enabled</Name>
                <Operations>RW</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Optional</Mandatory>
                <Type>Boolean</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Enable or disable LED blinking mode. Only applicable for LED type GPIOs. When enabled, the LED blinks at the interval specified in Blink Interval.]]></Description>
            </Item>
            <Item ID="5">
                <Name>Blink Interval</Name>
                <Operations>RW</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Optional</Mandatory>
                <Type>Integer</Type>
                <RangeEnumeration>100..10000</RangeEnumeration>
                <Units>ms</Units>
                <Description><![CDATA[LED blink interval in milliseconds for the on/off cycle. Only used when Blink Enabled is true.]]></Description>
            </Item>
            <Item ID="6">
                <Name>Trigger Mode</Name>
                <Operations>RW</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Optional</Mandatory>
                <Type>Integer</Type>
                <RangeEnumeration>0..3</RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[LED trigger mode: 0=None (manual control), 1=Network device activity, 2=Timer-based, 3=Default-on (inverted). This controls automatic LED behavior based on system events.]]></Description>
            </Item>
            <Item ID="7">
                <Name>Button State</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Optional</Mandatory>
                <Type>Boolean</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Current button state: true=Pressed, false=Released. Only applicable for button type GPIOs. This is a real-time reading of the button input.]]></Description>
            </Item>
            <Item ID="8">
                <Name>Button Press Count</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Optional</Mandatory>
                <Type>Integer</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Total number of button press events detected since last counter reset or system boot. Only applicable for button type GPIOs.]]></Description>
            </Item>
        </Resources>
        <Description2><![CDATA[]]></Description2>
    </Object>
</LWM2M>
