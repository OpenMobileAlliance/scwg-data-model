<?xml version="1.0" encoding="UTF-8"?>
<LWM2M xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:noNamespaceSchemaLocation="http://openmobilealliance.org/tech/profiles/LWM2M.xsd">
	<Object ObjectType="MODefinition">
		<Name>Mesh neighbor discovery</Name>
		<Description1>This object provides visibility of devices neighboring in a mesh network.</Description1>
		<ObjectID>603</ObjectID>
		<ObjectURN>urn:oma:lwm2m:x:603</ObjectURN>
		<LWM2MVersion>1.0</LWM2MVersion>
		<ObjectVersion>1.0</ObjectVersion>
		<MultipleInstances>Single</MultipleInstances>
		<Mandatory>Optional</Mandatory>
		<Resources>
			<Item ID="0">
				<Name>Global Address</Name>
				<Operations>R</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Mandatory</Mandatory>
				<Type>String</Type>
				<RangeEnumeration></RangeEnumeration>
				<Units></Units>
				<Description>Address that uniquely identifies the neighbour node.</Description>
			</Item>
			<Item ID="1">
				<Name>Link local address</Name>
				<Operations>R</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Optional</Mandatory>
				<Type>String</Type>
				<RangeEnumeration></RangeEnumeration>
				<Units></Units>
				<Description>Link local address that identifies the neighbour node.</Description>
			</Item>
            <Item ID="2">
				<Name>State</Name>
				<Operations>R</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Mandatory</Mandatory>
				<Type>Integer</Type>
				<RangeEnumeration></RangeEnumeration>
				<Units></Units>
				<Description>State of the neighbor node.</Description>
			</Item>
            <Item ID="3">
				<Name>ETX</Name>
				<Operations>R</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Optional</Mandatory>
				<Type>Float</Type>
				<RangeEnumeration></RangeEnumeration>
				<Units></Units>
				<Description>Quality of a path between two nodes in a mesh network.</Description>
			</Item>
            <Item ID="4">
				<Name>RSS</Name>
				<Operations>R</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Optional</Mandatory>
				<Type>Integer</Type>
				<RangeEnumeration></RangeEnumeration>
				<Units>dBm</Units>
				<Description>Perceived radio signal strength of a neighbour.</Description>
			</Item>
            <Item ID="5">
				<Name>Preference</Name>
				<Operations>R</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Optional</Mandatory>
				<Type>Integer</Type>
				<RangeEnumeration></RangeEnumeration>
				<Units></Units>
				<Description>Priority of link usage in comparison with other neighbours for packet forwarding.</Description>
			</Item>
            <Item ID="7">
				<Name>Rank</Name>
				<Operations>R</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Optional</Mandatory>
				<Type>Integer</Type>
				<RangeEnumeration></RangeEnumeration>
				<Units></Units>
				<Description>Individual position relative to other nodes with respect in a hierarchical network arrangement.</Description>
			</Item>
            <Item ID="8">
				<Name>Cost</Name>
				<Operations>R</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Optional</Mandatory>
				<Type>Integer</Type>
				<RangeEnumeration></RangeEnumeration>
				<Units></Units>
				<Description>Path cost to the root through the neighbour node.</Description>
			</Item>
			<Item ID="5518">
				<Name>Timestamp</Name>
				<Operations>R</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Optional</Mandatory>
				<Type>Time</Type>
				<RangeEnumeration></RangeEnumeration>
				<Units></Units>
				<Description>The timestamp of when the measurement was performed.</Description>
			</Item>
			<Item ID="28001">
				<Name>Neighbor discovery</Name>
				<Operations>E</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Mandatory</Mandatory>
				<Type></Type>
				<RangeEnumeration></RangeEnumeration>
				<Units></Units>
				<Description>Triggers the discovery of neighbor nodes.</Description>
			</Item>
			<Item ID="28002">
				<Name>Simple neighbor table</Name>
				<Operations>R</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Optional</Mandatory>
				<Type>String</Type>
				<RangeEnumeration></RangeEnumeration>
				<Units></Units>
				<Description>Table containing the EUI, Rank, Cost, ETX and RSSI of each neighbor device in the mesh network.</Description>
			</Item>
			<Item ID="28003">
				<Name>RSSI threshold</Name>
				<Operations>RW</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Optional</Mandatory>
				<Type>Integer</Type>
				<RangeEnumeration></RangeEnumeration>
				<Units>dBm</Units>
				<Description>PHY's RX power threshold. The device will drop packects from neighbor nodes with signal strenght below the threshold.</Description>
			</Item>
		</Resources>
		<Description2></Description2>
	</Object>
</LWM2M>
