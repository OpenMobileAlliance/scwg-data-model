<LWM2M xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://www.openmobilealliance.org/tech/profiles/LWM2M.xsd">
    <Object ObjectType="MODefinition">
        <Name>Ethernet Interface</Name>
        <Description1><![CDATA[This LwM2M Object provides management and monitoring of Ethernet network interfaces on OpenWRT-based routers. It supports multiple instances for managing different physical Ethernet ports (WAN, LAN, etc.), providing real-time statistics on link status, speed, duplex mode, and traffic counters. Essential for monitoring router connectivity and network performance.]]></Description1>
        <ObjectID>10514</ObjectID>
        <ObjectURN>urn:oma:lwm2m:x:10514</ObjectURN>
        <LWM2MVersion>1.0</LWM2MVersion>
        <ObjectVersion>1.0</ObjectVersion>
        <MultipleInstances>Multiple</MultipleInstances>
        <Mandatory>Optional</Mandatory>
        <Resources>
            <Item ID="0">
                <Name>Interface Name</Name>
                <Operations>RW</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Mandatory</Mandatory>
                <Type>String</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Network interface name (e.g., "eth0", "eth1", "wan"). This identifies the specific Ethernet interface on the system.]]></Description>
            </Item>
            <Item ID="1">
                <Name>Port Type</Name>
                <Operations>RW</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Mandatory</Mandatory>
                <Type>Integer</Type>
                <RangeEnumeration>0..1</RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Ethernet port type: 0=LAN (local network), 1=WAN (internet connection).]]></Description>
            </Item>
            <Item ID="2">
                <Name>Speed</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Mandatory</Mandatory>
                <Type>Integer</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units>Mbps</Units>
                <Description><![CDATA[Current link speed in megabits per second (e.g., 10, 100, 1000, 2500, 10000). Returns 0 if link is down.]]></Description>
            </Item>
            <Item ID="3">
                <Name>Duplex</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Mandatory</Mandatory>
                <Type>Integer</Type>
                <RangeEnumeration>0..1</RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Duplex mode: 0=Half-duplex, 1=Full-duplex. Full-duplex allows simultaneous transmit and receive.]]></Description>
            </Item>
            <Item ID="4">
                <Name>Link Status</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Mandatory</Mandatory>
                <Type>Boolean</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Physical link status: true=Link up (cable connected and link established), false=Link down.]]></Description>
            </Item>
            <Item ID="5">
                <Name>MAC Address</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Mandatory</Mandatory>
                <Type>String</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Hardware MAC address of the interface in colon-separated hexadecimal format (e.g., "00:11:22:33:44:55").]]></Description>
            </Item>
            <Item ID="6">
                <Name>MTU</Name>
                <Operations>RW</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Optional</Mandatory>
                <Type>Integer</Type>
                <RangeEnumeration>576..9000</RangeEnumeration>
                <Units>B</Units>
                <Description><![CDATA[Maximum Transmission Unit size in bytes. Standard Ethernet MTU is 1500. Jumbo frames up to 9000 bytes may be supported.]]></Description>
            </Item>
            <Item ID="7">
                <Name>Total Bytes Sent</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Mandatory</Mandatory>
                <Type>Integer</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units>B</Units>
                <Description><![CDATA[Total number of bytes transmitted on this interface since last counter reset or system boot.]]></Description>
            </Item>
            <Item ID="8">
                <Name>Total Bytes Received</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Mandatory</Mandatory>
                <Type>Integer</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units>B</Units>
                <Description><![CDATA[Total number of bytes received on this interface since last counter reset or system boot.]]></Description>
            </Item>
            <Item ID="9">
                <Name>Total Packets Sent</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Optional</Mandatory>
                <Type>Integer</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Total number of packets transmitted on this interface since last counter reset or system boot.]]></Description>
            </Item>
            <Item ID="10">
                <Name>Total Packets Received</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Optional</Mandatory>
                <Type>Integer</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Total number of packets received on this interface since last counter reset or system boot.]]></Description>
            </Item>
            <Item ID="11">
                <Name>Transmit Errors</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Optional</Mandatory>
                <Type>Integer</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Total number of transmission errors encountered on this interface.]]></Description>
            </Item>
            <Item ID="12">
                <Name>Receive Errors</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Optional</Mandatory>
                <Type>Integer</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Total number of receive errors encountered on this interface including CRC errors, frame errors, etc.]]></Description>
            </Item>
            <Item ID="13">
                <Name>Interface Enabled</Name>
                <Operations>RW</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Mandatory</Mandatory>
                <Type>Boolean</Type>
                <RangeEnumeration></RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Enable or disable the interface administratively. When disabled, the interface is brought down regardless of physical link state.]]></Description>
            </Item>
        </Resources>
        <Description2><![CDATA[]]></Description2>
    </Object>
</LWM2M>
